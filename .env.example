# ───────────────────────────────────────────────────────
# FormKitCN Environment Variables
# Copy this file to .env.local and fill in the values.
# All vars are optional — features only activate when set.
# ───────────────────────────────────────────────────────

# ── Site URL ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://formkitcn.jolyui.dev"

# ── Search Engine Verification ───────────────────────────
# Get these from each platform's webmaster tools dashboard.
# Google Search Console  → https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Bing Webmaster Tools   → https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=""

# Yandex Webmaster       → https://webmaster.yandex.com
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=""

# Pinterest              → https://pinterest.com/settings
NEXT_PUBLIC_PINTEREST_SITE_VERIFICATION=""

# Baidu Webmaster        → https://ziyuan.baidu.com
NEXT_PUBLIC_BAIDU_SITE_VERIFICATION=""

# ── Analytics ────────────────────────────────────────────
# Google Analytics 4 (GA4) — measurement ID (starts with "G-")
# Get it from → https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Google Tag Manager — container ID (starts with "GTM-")
# Get it from → https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=""

# Microsoft Clarity — project ID
# Get it from → https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Plausible Analytics — your domain (e.g. "formkitcn.jolyui.dev")
# Get it from → https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# Optional: self-hosted Plausible script URL
NEXT_PUBLIC_PLAUSIBLE_SRC="https://plausible.io/js/script.js"

# Umami Analytics — website ID
# Get it from → https://umami.is
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
# Optional: self-hosted Umami script URL
NEXT_PUBLIC_UMAMI_SRC="https://cloud.umami.is/script.js"
